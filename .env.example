# Optional: enables the AI Advisor tab.
# Get a key from https://console.anthropic.com (pay-as-you-go, separate from a Claude subscription).
# Copy this file to ".env" and fill in your key, then restart the server.
# Without it, the app works fully — only the Advisor tab shows a "not configured" message.
ANTHROPIC_API_KEY=

# Optional: change the port (default 5173)
# PORT=5173
