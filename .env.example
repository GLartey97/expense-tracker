# Optional: enables the AI Advisor tab.
# Get a key from https://console.anthropic.com (pay-as-you-go, separate from a Claude subscription).
# Copy this file to ".env" and fill in your key, then restart the server.
# Without it, the app works fully — only the Advisor tab shows a "not configured" message.
ANTHROPIC_API_KEY=

# Recommended for deployment: a Postgres connection string for persistent storage.
# Without it, data is stored in a local file (data/db.json) that is wiped whenever
# a host with an ephemeral disk (e.g. Render free) restarts — which logs everyone out.
# Free Postgres: https://neon.tech  (copy the "connection string")
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Optional: change the port (default 5173)
# PORT=5173
